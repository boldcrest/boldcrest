# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local design previews / mockups
/previews

# Claude local working dir (launch configs, worktrees) — never commit
/.claude

# Team headshots live in Sanity, not the repo
/public/Team Photos

# Sample/in-progress pages kept local until ready to ship
/src/app/services-sample

# typescript
*.tsbuildinfo
next-env.d.ts
.DS_Store
